# ==============================================================================
# SSE Project .gitignore
# ==============================================================================

# 1. Environment & Dependency Managers
.venv/
venv/
env/
.env
.tox/
.poetry/
pypackages/

# 2. Python Caches and Bytecode
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# 3. Numba Compiled Output Cache
__numba_cache__/
.numba_cache/

# 4. OS Specific Files
.DS_Store
Thumbs.db

# 5. Local IDE Settings
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# 6. Simulation & Output Files (CRITICAL: Do not commit simulation runs!)
*.h5
*.hdf5
*.arrow
*.parquet
*.csv
*.log
tests/regression/gold_standards/local_temp/

# 7. Distribution / Packaging / Builds
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
